{
  "name": "an-wechat",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:server": "cd packages/server && npm run dev",
    "dev:web": "cd packages/web && npm run dev",
    "dev:mobile": "cd packages/mobile && npm start",
    "dev:desktop": "cd packages/desktop && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:web": "cd packages/web && npm run build",
    "build:desktop": "cd packages/desktop && npm run build",
    "build:desktop:win": "cd packages/desktop && npm run build:win",
    "build:desktop:mac": "cd packages/desktop && npm run build:mac",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "concurrently": "^9.1.0"
  }
}
